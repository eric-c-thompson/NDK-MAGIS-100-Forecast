        "import math\n",
        "import itertools\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib.lines import Line2D\n",
        "from matplotlib.patches import Patch\n",
        "\n",
        "# -----------------------------\n",
        "# Constants (SI)\n",
        "# -----------------------------\n",
        "C = 299_792_458.0\n",
        "L_PLANCK = 1.616_255e-35\n",
        "\n",
        "def predicted_dephasing(\n",
        "    T,\n",
        "    n,\n",
        "    k_eff,\n",
        "    w_coh,\n",
        "    lambda_coh0,\n",
        "    I_star_over_A=3.28,\n",
        "    chi=1.0,\n",
        "    eta=math.pi\n",
        "):\n",
        "    \"\"\"\n",
        "    Closure-informed fixed-cell ansatz:\n",
        "        D_pred = (pi*chi/eta) * (I_*/A) * c*l_P*T*n^2*k_eff^2 * (w_coh/lambda_coh0)^2\n",
        "    \"\"\"\n",
        "    pref = (math.pi * chi / eta) * I_star_over_A\n",
        "    geom = C * L_PLANCK * T * n**2 * k_eff**2\n",
        "    ratio = (w_coh / lambda_coh0)**2\n",
        "    return pref * geom * ratio\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# Fixed MAGIS-like time\n",
        "# -----------------------------\n",
        "T_fixed = 3.0\n",
        "\n",
        "# Tightened closure-informed sweep\n",
        "# These bands represent model-side sensitivity to the chosen coherence-parameter sweep,\n",
        "# not experimental confidence intervals.\n",
        "w_coh_values = [10e-6, 30e-6, 100e-6]   # 10, 30, 100 microns\n",
        "lambda_coh0_values = [1e-6, 3e-6]       # 1, 3 microns\n",
        "\n",
        "# Fixed structural factors\n",
        "chi_values = [1.0]\n",
        "eta_values = [math.pi]\n",
        "I_star_over_A_values = [3.28]\n",
        "k_eff_values = [1.0e7]\n",
        "\n",
        "# Temperature knob (relative scaling only)\n",
        "Theta_ref = 100.0   # pK\n",
        "Theta_low = 50.0    # pK\n",
        "Theta_high = 200.0  # pK\n",
        "\n",
        "scale_low = Theta_low / Theta_ref\n",
        "scale_high = Theta_high / Theta_ref\n",
        "\n",
        "# Plot domain\n",
        "n_vals = np.logspace(1, 3.3, 300)  # 10 to ~2000\n",
        "\n",
        "# Colors\n",
        "LOW_COLOR = \"#1f77b4\"    # blue\n",
        "MID_COLOR = \"#7b1fa2\"    # purple\n",
        "HIGH_COLOR = \"#c62828\"   # red\n",
        "THRESHOLD_COLOR = \"black\"\n",
        "\n",
        "# -----------------------------\n",
        "# Compute reference sweep band at T = 3 s\n",
        "# -----------------------------\n",
        "p25s, meds, p75s = [], [], []\n",
        "\n",
        "for n_val in n_vals:\n",
        "    vals = []\n",
        "    for w_val, lambda_val, chi_val, eta_val, Istar_val, k_val in itertools.product(\n",
        "        w_coh_values,\n",
        "        lambda_coh0_values,\n",
        "        chi_values,\n",
        "        eta_values,\n",
        "        I_star_over_A_values,\n",
        "        k_eff_values\n",
        "    ):\n",
        "        vals.append(\n",
        "            predicted_dephasing(\n",
        "                T=T_fixed,\n",
        "                n=float(n_val),\n",
        "                k_eff=k_val,\n",
        "                w_coh=w_val,\n",
        "                lambda_coh0=lambda_val,\n",
        "                I_star_over_A=Istar_val,\n",
        "                chi=chi_val,\n",
        "                eta=eta_val\n",
        "            )\n",
        "        )\n",
        "\n",
        "    arr = np.array(vals)\n",
        "    p25s.append(np.percentile(arr, 25))\n",
        "    meds.append(np.median(arr))\n",
        "    p75s.append(np.percentile(arr, 75))\n",
        "\n",
        "p25s = np.array(p25s)\n",
        "meds = np.array(meds)\n",
        "p75s = np.array(p75s)\n",
        "\n",
        "# Temperature-rescaled medians\n",
        "med_low = meds * scale_low\n",
        "med_ref = meds\n",
        "med_high = meds * scale_high\n",
        "\n",
        "# Temperature-rescaled sweep bands\n",
        "p25_low, p75_low = p25s * scale_low, p75s * scale_low\n",
        "p25_ref, p75_ref = p25s, p75s\n",
        "p25_high, p75_high = p25s * scale_high, p75s * scale_high\n",
        "\n",
        "# -----------------------------\n",
        "# Plot\n",
        "# -----------------------------\n",
        "plt.rcParams[\"font.family\"] = \"sans-serif\"\n",
        "fig, ax = plt.subplots(figsize=(10.5, 7.5))\n",
        "\n",
        "# Shaded parameter-sweep bands for each temperature\n",
        "ax.fill_between(\n",
        "    n_vals, p25_low, p75_low,\n",
        "    color=LOW_COLOR, alpha=0.16, zorder=1\n",
        ")\n",
        "ax.fill_between(\n",
        "    n_vals, p25_ref, p75_ref,\n",
        "    color=MID_COLOR, alpha=0.18, zorder=2\n",
        ")\n",
        "ax.fill_between(\n",
        "    n_vals, p25_high, p75_high,\n",
        "    color=HIGH_COLOR, alpha=0.16, zorder=1\n",
        ")\n",
        "\n",
        "# Solid median lines\n",
        "ax.plot(\n",
        "    n_vals, med_low,\n",
        "    color=LOW_COLOR,\n",
        "    linewidth=2.4,\n",
        "    linestyle=\"-\",\n",
        "    zorder=3\n",
        ")\n",
        "\n",
        "ax.plot(\n",
        "    n_vals, med_ref,\n",
        "    color=MID_COLOR,\n",
        "    linewidth=2.8,\n",
        "    linestyle=\"-\",\n",
        "    zorder=4\n",
        ")\n",
        "\n",
        "ax.plot(\n",
        "    n_vals, med_high,\n",
        "    color=HIGH_COLOR,\n",
        "    linewidth=2.4,\n",
        "    linestyle=\"-\",\n",
        "    zorder=3\n",
        ")\n",
        "\n",
        "# Reference vertical lines\n",
        "ax.axvline(100, linestyle=\":\", linewidth=1.2, color=\"gray\", alpha=0.6)\n",
        "ax.axvline(1000, linestyle=\":\", linewidth=1.2, color=\"gray\", alpha=0.6)\n",
        "\n",
        "# Threshold lines in black\n",
        "ax.axhline(\n",
        "    1e-3,\n",
        "    linestyle=\"--\",\n",
        "    linewidth=1.3,\n",
        "    color=THRESHOLD_COLOR\n",
        ")\n",
        "ax.axhline(\n",
        "    1e-2,\n",
        "    linestyle=\"-.\",\n",
        "    linewidth=1.3,\n",
        "    color=THRESHOLD_COLOR\n",
        ")\n",
        "\n",
        "# Axes\n",
        "ax.set_xscale(\"log\")\n",
        "ax.set_yscale(\"log\")\n",
        "ax.set_xlabel(r\"Large Momentum Transfer Order $n$ (laser kicks)\", fontsize=11)\n",
        "ax.set_ylabel(r\"Predicted Dephasing $D_{\\rm pred} \\equiv -\\ln V_{\\rm res}$\", fontsize=11)\n",
        "ax.set_title(\n",
        "    \"MAGIS-Focused Closure-Informed Dephasing Forecast\\n\"\n",
        "    r\"Fixed $T=3.0\\,\\mathrm{s}$, Fixed $\\eta=\\pi$, Fixed $\\chi=1$, Temperature as the Control Knob\",\n",
        "    fontsize=13,\n",
        "    fontweight=\"bold\"\n",
        ")\n",
        "\n",
        "# Grid\n",
        "ax.grid(True, which=\"both\", alpha=0.25)\n",
        "\n",
        "# Annotations\n",
        "TEXT_BBOX = dict(facecolor=\"white\", alpha=0.90, edgecolor=\"none\", pad=2.4)\n",
        "ymin, ymax = ax.get_ylim()\n",
        "\n",
        "ax.text(\n",
        "    100, ymin * 1.5,\n",
        "    \"Current Tech\\n(n=100)\",\n",
        "    ha=\"center\", va=\"bottom\",\n",
        "    fontsize=10, color=\"gray\",\n",
        "    bbox=TEXT_BBOX\n",
        ")\n",
        "\n",
        "ax.text(\n",
        "    1000, ymin * 1.9,\n",
        "    \"MAGIS-100\\n(n=1000)\",\n",
        "    ha=\"center\", va=\"bottom\",\n",
        "    fontsize=10, color=\"gray\",\n",
        "    bbox=TEXT_BBOX\n",
        ")\n",
        "\n",
        "ax.text(\n",
        "    0.985, 0.14,\n",
        "    r\"Fixed time: $T=3.0\\,\\mathrm{s}$\" \"\\n\"\n",
        "    r\"Fixed geometry: $\\eta=\\pi,\\ \\chi=1$\" \"\\n\"\n",
        "    r\"Bands show model-side sweep in $w_{\\rm coh}$ and $\\lambda_{\\rm coh,0}$\" \"\\n\"\n",
