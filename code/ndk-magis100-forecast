        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from mpl_toolkits.mplot3d import Axes3D  # noqa: F401\n",
        "import math\n",
        "\n",
        "# -----------------------------\n",
        "# Representative Constants (SI)\n",
        "# -----------------------------\n",
        "C = 299_792_458.0\n",
        "L_PLANCK = 1.616_255e-35\n",
        "K_EFF = 1.0e7\n",
        "\n",
        "# Representative fixed coherence / bridge parameters\n",
        "W_COH = 30e-6        # 30 microns (transverse coherence-support width)\n",
        "LAMBDA_COH0 = 1e-6   # 1 micron (pre-split coherence length)\n",
        "I_STAR_OVER_A = 3.28\n",
        "CHI = 1.0\n",
        "ETA = math.pi        # closure-informed geometry choice\n",
        "\n",
        "# -----------------------------\n",
        "# NDK Residual Dephasing Function\n",
        "# -----------------------------\n",
        "def calc_dpred(n: np.ndarray, T: np.ndarray) -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Representative fixed-parameter dephasing surface:\n",
        "\n",
        "        D_pred = (pi*chi/eta) * (I_*/A) * c*l_P*T*n^2*k_eff^2 * (w_coh/lambda_coh0)^2\n",
        "\n",
        "    This is an illustrative slice through parameter space, not a full uncertainty-aware forecast band.\n",
        "    \"\"\"\n",
        "    pref = (math.pi * CHI / ETA) * I_STAR_OVER_A\n",
        "    geom = C * L_PLANCK * T * (n**2) * (K_EFF**2)\n",
        "    ratio = (W_COH / LAMBDA_COH0)**2\n",
        "    return pref * geom * ratio\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# Generate Grid Data\n",
        "# -----------------------------\n",
        "# Sweep n from 100 to 1000 (MAGIS-like LMT regime)\n",
        "n_vals = np.linspace(100, 1000, 60)\n",
        "\n",
        "# Sweep T from 1s to 9s (MAGIS-100 design target regime)\n",
        "T_vals = np.linspace(1, 9, 60)\n",
        "\n",
        "N, T = np.meshgrid(n_vals, T_vals)\n",
        "D_PRED = calc_dpred(N, T)\n",
        "\n",
        "# -----------------------------\n",
        "# Plot\n",
        "# -----------------------------\n",
        "plt.rcParams[\"font.family\"] = \"sans-serif\"\n",
        "fig = plt.figure(figsize=(12, 8))\n",
        "ax = fig.add_subplot(111, projection=\"3d\")\n",
        "\n",
        "# Surface\n",
        "surf = ax.plot_surface(\n",
        "    N, T, D_PRED,\n",
        "    cmap=\"viridis\",\n",
        "    edgecolor=\"none\",\n",
        "    alpha=0.92\n",
        ")\n",
        "\n",
        "# Bottom contours for visual guidance\n",
        "zmin = 0.0\n",
        "ax.contour(\n",
        "    N, T, D_PRED,\n",
        "    zdir=\"z\",\n",
        "    offset=zmin,\n",
        "    cmap=\"viridis\",\n",
        "    alpha=0.55\n",
        ")\n",
        "\n",
        "# Formatting\n",
        "ax.set_title(\n",
        "    \"Illustrative NDK Residual Dephasing Surface\\n\"\n",
        "    \"Representative Fixed Parameters: Joint Scaling with LMT Order ($n$) and Time ($T$)\",\n",
        "    fontsize=14,\n",
        "    fontweight=\"bold\",\n",
        "    pad=20\n",
